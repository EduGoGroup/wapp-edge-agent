# Binarios compilados (anclados a la raíz para no ignorar cmd/agent/)
/agent
/wapp-ctl
/wapp-edge-agent
/wapp-agent
*.exe
*.exe~
*.test
*.out

# Directorios de salida
bin/
dist/

# Entornos y secretos
.env
.env.*

# Material criptográfico — JAMÁS al repo (zero-knowledge, ADR-0007). La DEK del
# spike vive en dek.key (custodia provisional; en v1 va al keystore del SO).
dek.key
*.key

# Bases de datos locales (solo en desarrollo; el .db real tiene datos sensibles)
*.db
*.db-shm
*.db-wal

# Runtime del plano de control (Unix socket + PID file del supervisor)
*.sock
*.pid

# Data dirs y configs de prueba locales (MP-02 D5): árboles de store/DEK/sessions y YAMLs de
# ambiente sueltos que NO deben commitearse. Contienen sesiones reales del usuario — no borrar a
# mano; solo mantenerlos fuera de git. La ruta sagrada real vive en el home del usuario, no aquí.
edgedata-*/
edge-*.yaml

# Vendor (descomentar si se usa go mod vendor)
# vendor/

# go workspace — SOLO desarrollo local (overlay de wapp-shared sin publicar)
go.work
go.work.sum

# macOS
.DS_Store

# IDEs
.idea/
.vscode/
*.swp
*.swo
